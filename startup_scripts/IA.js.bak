// Server Script
EntityJSEvents.modifyEntity(event => {
    event.modify("minecraft:zombie", modifyBuilder => {
        modifyBuilder.onHurt(context => {
            const { entity, damageSource, damageAmount } = context;
            
            const maxHealth = entity.getAttribute("minecraft:generic.max_health").value;
            const currentHealth = entity.health;
            
            // 检查半血条件
            if (currentHealth <= maxHealth / 2) {
                // 检查冷却时间(防止频繁召唤)
                const lastSummonTime = entity.persistentData.getLong("lastSummonTime");
                const currentTime = Date.now();
                const cooldown = 10000; // 10秒冷却
                
                if (currentTime - lastSummonTime >= cooldown) {
                    // 更新最后召唤时间
                    entity.persistentData.putLong("lastSummonTime", currentTime);
                    
                    // 召唤僵尸
                    summonReinforcements(entity);
                }
            }
        });
    });
});

function summonReinforcements(entity) {
    const level = entity.level;
    const EntityType = Java.loadClass("net.minecraft.world.entity.EntityType");
    const BlockPos = Java.loadClass("net.minecraft.core.BlockPos");
    
    // 播放召唤音效
    level.playSound(null, entity.x, entity.y, entity.z, 
        "minecraft:entity.evoker.prepare_summon", 
        "masters", 1.0, 1.0);
    
    // 生成召唤粒子效果
    for (let i = 0; i < 20; i++) {
        level.addParticle("minecraft:dragon_breath",
            entity.x + (Math.random() - 0.5) * 3,
            entity.y + 1 + Math.random() * 2,
            entity.z + (Math.random() - 0.5) * 3,
            0, 0, 0);
    }
    
    // 在周围3-5格范围内生成2-4个僵尸
    const zombieCount = 2 + Math.floor(Math.random() * 3);
    
    for (let i = 0; i < zombieCount; i++) {
        const angle = Math.random() * Math.PI * 2;
        const radius = 3 + Math.random() * 2;
        
        const spawnX = entity.x + Math.cos(angle) * radius;
        const spawnZ = entity.z + Math.sin(angle) * radius;
        
        // 检查生成位置是否安全
        const spawnPos = new BlockPos(Math.floor(spawnX), Math.floor(entity.y), Math.floor(spawnZ));
        if (!level.getBlockState(spawnPos).isSuffocating(level, spawnPos)) {
            const zombie = EntityType.ZOMBIE.create(level);
            
            if (zombie) {
                zombie.moveTo(spawnX, entity.y, spawnZ, entity.yRot, entity.xRot);
                
                // 给召唤的僵尸一些增益效果
                zombie.addEffect("minecraft:speed", 600, 1); // 速度II, 30秒
                zombie.addEffect("minecraft:strength", 600, 0); // 力量I, 30秒
                
                level.addFreshEntity(zombie);
                
                // 让僵尸攻击伤害源
                if (entity.lastHurtByMob) {
                    zombie.setTarget(entity.lastHurtByMob);
                }
            }
        }
    }
}